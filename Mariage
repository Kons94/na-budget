<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>N | A — Budget & Dépenses</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #f5f0e8; --cream-dark: #ede8de; --ink: #2c2825; --ink-light: #5a544e;
    --gold: #b8986a; --gold-light: #d4b896; --gold-pale: #f0e8d8; --white: #fdfaf5; --border: #d4c9b4;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--cream); color: var(--ink); font-family: 'Cormorant Garamond', serif; min-height: 100vh; }

  #sync-bar { position: fixed; top: 0; left: 0; right: 0; background: var(--ink); color: var(--cream); text-align: center; font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 2px; padding: 6px; z-index: 999; transform: translateY(-100%); transition: transform 0.3s; }
  #sync-bar.show { transform: translateY(0); }
  #sync-bar.ok { background: #4a7a4a; }
  #sync-bar.err { background: #8a3a2a; }

  header { background: var(--white); border-bottom: 1px solid var(--border); padding: 44px 24px 24px; text-align: center; }
  .logo { font-family: 'Cinzel', serif; font-size: 52px; font-weight: 600; letter-spacing: 8px; color: var(--ink); display: flex; align-items: center; justify-content: center; }
  .logo-sep { font-weight: 300; font-size: 40px; color: var(--gold); margin: 0 6px; }
  .subtitle { font-family: 'Great Vibes', cursive; font-size: 22px; color: var(--ink-light); margin-top: 6px; }

  .timer-bar { background: var(--ink); color: var(--cream); text-align: center; padding: 14px 24px; display: flex; align-items: center; justify-content: center; gap: 28px; flex-wrap: wrap; }
  .timer-label { font-family: 'Great Vibes', cursive; font-size: 18px; color: var(--gold-light); }
  .timer-blocks { display: flex; gap: 16px; align-items: center; }
  .timer-block { text-align: center; }
  .timer-num { font-family: 'Cinzel', serif; font-size: 28px; font-weight: 600; color: var(--gold-light); line-height: 1; }
  .timer-unit { font-family: 'Cormorant Garamond', serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--cream); opacity: 0.7; margin-top: 2px; }
  .timer-dot { color: var(--gold); font-size: 24px; }

  .tabs { display: flex; justify-content: center; padding: 28px 24px 0; max-width: 1100px; margin: 0 auto; }
  .tab-btn { font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; padding: 12px 32px; border: 1px solid var(--border); background: var(--cream-dark); color: var(--ink-light); cursor: pointer; transition: all 0.2s; }
  .tab-btn:first-child { border-radius: 2px 0 0 2px; }
  .tab-btn:last-child { border-radius: 0 2px 2px 0; }
  .tab-btn.active { background: var(--ink); color: var(--cream); border-color: var(--ink); }
  .tab-btn:hover:not(.active) { background: var(--gold-pale); border-color: var(--gold); }

  main { max-width: 1100px; margin: 0 auto; padding: 24px; }
  .panel { display: none; } .panel.active { display: block; }

  .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
  .grand-total-bar { background: var(--white); border: 1px solid var(--border); border-radius: 4px; padding: 18px 28px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; flex: 1; }
  .grand-total-bar h2 { font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 3px; font-weight: 400; color: var(--ink-light); text-transform: uppercase; }
  .grand-total-amount { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 600; color: var(--ink); }
  .grand-paid { font-size: 14px; color: var(--gold); margin-left: 16px; }

  .refresh-btn { background: none; border: 1px solid var(--border); border-radius: 2px; padding: 10px 16px; font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 2px; color: var(--ink-light); cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .refresh-btn:hover { border-color: var(--gold); color: var(--gold); }

  .category-section { margin-bottom: 24px; background: var(--white); border: 1px solid var(--border); border-radius: 4px; overflow: hidden; }
  .cat-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; background: var(--cream-dark); border-bottom: 1px solid var(--border); cursor: pointer; user-select: none; }
  .cat-header-left { display: flex; align-items: center; gap: 12px; }
  .cat-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
  .cat-name { font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; font-weight: 400; color: var(--ink); }
  .cat-total { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; color: var(--ink); }
  .cat-toggle { color: var(--gold); font-size: 18px; transition: transform 0.2s; }
  .cat-toggle.open { transform: rotate(180deg); }

  .cat-body { padding: 0 0 8px; }
  table { width: 100%; border-collapse: collapse; }
  th { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; font-weight: 400; color: var(--ink-light); padding: 10px 16px; text-align: left; border-bottom: 1px solid var(--cream-dark); }
  td { padding: 9px 16px; font-size: 16px; color: var(--ink); border-bottom: 1px solid var(--cream-dark); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--gold-pale); }

  .td-desc input, .td-price input, .td-note input { background: none; border: none; font-family: 'Cormorant Garamond', serif; font-size: 16px; color: var(--ink); width: 100%; outline: none; padding: 0; }
  .td-price { width: 110px; } .td-price input { text-align: right; width: 80px; }
  .td-note input { font-size: 14px; color: var(--ink-light); font-style: italic; }
  input:focus { border-bottom: 1px solid var(--gold); }

  .td-check { width: 40px; text-align: center; }
  .check-box { width: 18px; height: 18px; border: 1px solid var(--border); border-radius: 2px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; color: transparent; background: var(--cream); transition: all 0.15s; user-select: none; flex-shrink: 0; }
  .check-box.checked { background: var(--gold); border-color: var(--gold); color: white; }
  tr.purchased td { opacity: 0.55; } tr.purchased .td-desc input { text-decoration: line-through; }

  .td-status { width: 110px; }
  .status-sel { font-family: 'Cormorant Garamond', serif; font-size: 13px; border: 1px solid var(--border); background: var(--cream); color: var(--ink); padding: 3px 8px; border-radius: 20px; cursor: pointer; outline: none; width: 100%; }
  .status-sel.paid { border-color: #7ab37a; color: #4a7a4a; background: #f0f8f0; }
  .status-sel.pending { border-color: var(--gold); color: #8a6a2a; background: #fdf6e8; }

  .btn-del { background: none; border: none; color: var(--border); cursor: pointer; font-size: 16px; padding: 2px 6px; border-radius: 2px; transition: color 0.15s; line-height: 1; }
  .btn-del:hover { color: #c0604a; }
  .add-row-btn { display: flex; align-items: center; gap: 8px; margin: 10px 16px 4px; background: none; border: 1px dashed var(--border); border-radius: 2px; padding: 8px 16px; font-family: 'Cormorant Garamond', serif; font-size: 15px; color: var(--ink-light); cursor: pointer; width: calc(100% - 32px); transition: all 0.15s; font-style: italic; }
  .add-row-btn:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-pale); }

  .checklist-section { background: var(--white); border: 1px solid var(--border); border-radius: 4px; padding: 20px; margin-bottom: 24px; }
  .checklist-title { font-family: 'Cinzel', serif; font-size: 12px; letter-spacing: 3px; text-transform: uppercase; color: var(--ink-light); margin-bottom: 14px; display: flex; align-items: center; gap: 10px; }
  .checklist-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .checklist-items { list-style: none; }
  .checklist-item { display: flex; align-items: center; gap: 10px; padding: 7px 0; border-bottom: 1px solid var(--cream-dark); font-size: 16px; }
  .checklist-item:last-child { border-bottom: none; }
  .checklist-item.done .item-text { text-decoration: line-through; opacity: 0.5; }
  .item-text { flex: 1; background: none; border: none; font-family: 'Cormorant Garamond', serif; font-size: 16px; color: var(--ink); outline: none; }
  .item-text:focus { border-bottom: 1px solid var(--gold); }
  .add-check-row { display: flex; gap: 8px; margin-top: 12px; }
  .add-check-input { flex: 1; background: var(--cream); border: 1px solid var(--border); border-radius: 2px; padding: 8px 12px; font-family: 'Cormorant Garamond', serif; font-size: 16px; color: var(--ink); outline: none; font-style: italic; }
  .add-check-input:focus { border-color: var(--gold); }
  .btn-add-check { background: var(--ink); color: var(--cream); border: none; border-radius: 2px; padding: 8px 20px; font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 2px; cursor: pointer; transition: background 0.15s; }
  .btn-add-check:hover { background: var(--gold); }

  footer { text-align: center; padding: 32px; font-family: 'Great Vibes', cursive; font-size: 20px; color: var(--gold); opacity: 0.7; }

  @media (max-width: 600px) {
    .logo { font-size: 38px; } .timer-num { font-size: 22px; } th, td { padding: 8px 8px; }
    .tab-btn { padding: 10px 16px; font-size: 10px; }
  }
</style>
</head>
<body>

<div id="sync-bar">⟳ Synchronisation...</div>

<header>
  <div class="logo">N<span class="logo-sep">|</span>A</div>
  <div class="subtitle">Nadine & Abdelkader — 30 mai 2026</div>
</header>

<div class="timer-bar">
  <span class="timer-label">Notre grand jour dans...</span>
  <div class="timer-blocks">
    <div class="timer-block"><div class="timer-num" id="t-days">–</div><div class="timer-unit">Jours</div></div>
    <div class="timer-dot">·</div>
    <div class="timer-block"><div class="timer-num" id="t-hours">–</div><div class="timer-unit">Heures</div></div>
    <div class="timer-dot">·</div>
    <div class="timer-block"><div class="timer-num" id="t-mins">–</div><div class="timer-unit">Minutes</div></div>
    <div class="timer-dot">·</div>
    <div class="timer-block"><div class="timer-num" id="t-secs">–</div><div class="timer-unit">Secondes</div></div>
  </div>
</div>

<div class="tabs">
  <button class="tab-btn active" onclick="showPanel('mariage', this)">💍 Mariage</button>
  <button class="tab-btn" onclick="showPanel('appartement', this)">🏠 Appartement</button>
</div>

<main>
  <!-- MARIAGE -->
  <div id="panel-mariage" class="panel active">
    <div class="top-bar">
      <div class="grand-total-bar">
        <div><h2>Budget Total Mariage</h2><small style="font-size:13px;color:var(--ink-light);font-style:italic">Toutes catégories confondues</small></div>
        <div><span class="grand-total-amount" id="grand-total-mariage">0 €</span><span class="grand-paid" id="grand-paid-mariage"></span></div>
      </div>
      <button class="refresh-btn" onclick="loadFromCloud()">↻ Rafraîchir</button>
    </div>
    <div id="cats-mariage"></div>
    <div class="checklist-section">
      <div class="checklist-title">À faire / À acheter</div>
      <ul class="checklist-items" id="checklist-mariage"></ul>
      <div class="add-check-row">
        <input class="add-check-input" id="new-check-mariage" placeholder="Ajouter un élément..." onkeydown="if(event.key==='Enter') addCheck('mariage')">
        <button class="btn-add-check" onclick="addCheck('mariage')">+ Ajouter</button>
      </div>
    </div>
  </div>

  <!-- APPARTEMENT -->
  <div id="panel-appartement" class="panel">
    <div class="top-bar">
      <div class="grand-total-bar">
        <div><h2>Budget Total Appartement</h2><small style="font-size:13px;color:var(--ink-light);font-style:italic">Toutes pièces confondues</small></div>
        <div><span class="grand-total-amount" id="grand-total-appart">0 €</span><span class="grand-paid" id="grand-paid-appart"></span></div>
      </div>
      <button class="refresh-btn" onclick="loadFromCloud()">↻ Rafraîchir</button>
    </div>
    <div id="cats-appart"></div>
    <div class="checklist-section">
      <div class="checklist-title">À acheter pour l'appartement</div>
      <ul class="checklist-items" id="checklist-appart"></ul>
      <div class="add-check-row">
        <input class="add-check-input" id="new-check-appart" placeholder="Ajouter un élément..." onkeydown="if(event.key==='Enter') addCheck('appart')">
        <button class="btn-add-check" onclick="addCheck('appart')">+ Ajouter</button>
      </div>
    </div>
  </div>
</main>

<footer>N &amp; A ♡ 30 mai 2026</footer>

<script>
// ══════════ CONFIG ══════════
const API_KEY  = '$2a$10$YXlCnix2gZZtgX9eNhWaBujcJI8kCm/LK85blBeC/OPTmDx26rLOS';
const BIN_NAME = 'NA-Budget';
let BIN_ID = localStorage.getItem('na-bin-id') || null;

const MARIAGE_CATS = ['Mariage', 'Prestataire', 'Nadine', 'Kader'];
const APPART_CATS  = ['Cuisine', 'Salon', 'Chambre', 'Salle de bain', 'Frais global'];

let data = makeEmpty();
function makeEmpty() {
  return {
    mariage: Object.fromEntries(MARIAGE_CATS.map(c => [c, { rows:[], open:true }])),
    appart:  Object.fromEntries(APPART_CATS.map(c  => [c, { rows:[], open:true }])),
    checklist_mariage: [],
    checklist_appart:  []
  };
}
function ensureCats() {
  MARIAGE_CATS.forEach(c => { if(!data.mariage[c]) data.mariage[c] = {rows:[],open:true}; });
  APPART_CATS.forEach(c  => { if(!data.appart[c])  data.appart[c]  = {rows:[],open:true}; });
  if(!data.checklist_mariage) data.checklist_mariage = [];
  if(!data.checklist_appart)  data.checklist_appart  = [];
}
function makeRow() { return { id: Date.now()+Math.random(), desc:'', price:'', note:'', status:'todo' }; }

// ══════════ SYNC BAR ══════════
let syncT;
function showSync(msg, type='') {
  const b = document.getElementById('sync-bar');
  b.textContent = msg; b.className = 'show ' + type;
  clearTimeout(syncT); syncT = setTimeout(() => b.className = '', 2500);
}

// ══════════ JSONBIN API ══════════
async function loadFromCloud() {
  showSync('⟳ Chargement...');
  try {
    if (!BIN_ID) { await createBin(); return; }
    const res = await fetch(`https://api.jsonbin.io/v3/b/${BIN_ID}/latest`, {
      headers: { 'X-Master-Key': API_KEY }
    });
    if (res.status === 404) { BIN_ID = null; localStorage.removeItem('na-bin-id'); await createBin(); return; }
    if (!res.ok) throw new Error(res.status);
    data = (await res.json()).record;
    ensureCats(); renderAll();
    showSync('✓ À jour', 'ok');
  } catch(e) { showSync('⚠ Erreur réseau', 'err'); console.error(e); }
}

async function saveToCloud() {
  if (!BIN_ID) { await createBin(); return; }
  showSync('⟳ Sauvegarde...');
  try {
    const res = await fetch(`https://api.jsonbin.io/v3/b/${BIN_ID}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'X-Master-Key': API_KEY },
      body: JSON.stringify(data)
    });
    if (!res.ok) throw new Error(res.status);
    showSync('✓ Sauvegardé', 'ok');
  } catch(e) { showSync('⚠ Erreur sauvegarde', 'err'); console.error(e); }
}

async function createBin() {
  showSync('⟳ Première connexion...');
  try {
    const res = await fetch('https://api.jsonbin.io/v3/b', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Master-Key': API_KEY, 'X-Bin-Name': BIN_NAME, 'X-Bin-Private': 'true' },
      body: JSON.stringify(data)
    });
    if (!res.ok) throw new Error(res.status);
    BIN_ID = (await res.json()).metadata.id;
    localStorage.setItem('na-bin-id', BIN_ID);
    showSync('✓ Prêt !', 'ok');
    renderAll();
  } catch(e) { showSync('⚠ Clé API invalide ?', 'err'); console.error(e); }
}

let saveTimer;
function scheduleSave() { clearTimeout(saveTimer); saveTimer = setTimeout(saveToCloud, 1000); }

// ══════════ TABS ══════════
function showPanel(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  btn.classList.add('active');
}

// ══════════ RENDER ══════════
function renderAll() {
  renderPanel('mariage', data.mariage, MARIAGE_CATS, 'cats-mariage');
  renderPanel('appart',  data.appart,  APPART_CATS,  'cats-appart');
  updateGrandTotals(); renderChecklists();
}

function renderPanel(panel, catData, cats, containerId) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  cats.forEach(cat => {
    const rows = catData[cat].rows;
    const total = rows.reduce((s,r) => s+(parseFloat(r.price)||0), 0);
    const isOpen = catData[cat].open !== false;
    const sec = document.createElement('div');
    sec.className = 'category-section';
    sec.innerHTML = `
      <div class="cat-header" onclick="toggleCat('${panel}','${esc(cat)}')">
        <div class="cat-header-left"><div class="cat-dot"></div><div class="cat-name">${cat}</div></div>
        <div style="display:flex;align-items:center;gap:16px;">
          <div class="cat-total">${total.toLocaleString('fr-FR')} €</div>
          <span class="cat-toggle ${isOpen?'open':''}">▾</span>
        </div>
      </div>
      <div class="cat-body" style="display:${isOpen?'block':'none'}">
        <table><thead><tr>
          <th style="width:36px"></th><th>Description</th><th>Note</th>
          <th style="width:110px">Statut</th><th style="width:110px;text-align:right">Montant</th><th style="width:40px"></th>
        </tr></thead><tbody id="tbody-${panel}-${cat.replace(/\s/g,'_')}"></tbody></table>
        <button class="add-row-btn" onclick="addRow('${panel}','${esc(cat)}')">＋ Ajouter une dépense</button>
      </div>`;
    container.appendChild(sec);
    const tbody = document.getElementById(`tbody-${panel}-${cat.replace(/\s/g,'_')}`);
    rows.forEach(row => tbody.appendChild(makeRowEl(panel, cat, row)));
  });
}

function makeRowEl(panel, cat, row) {
  const tr = document.createElement('tr');
  if(row.status==='paid') tr.classList.add('purchased');
  const sc = row.status==='paid'?'paid':row.status==='pending'?'pending':'todo';
  const rid = String(row.id);
  tr.innerHTML = `
    <td class="td-check"><div class="check-box ${row.status==='paid'?'checked':''}" onclick="togglePaid('${panel}','${esc(cat)}','${rid}')">✓</div></td>
    <td class="td-desc"><input type="text" value="${esc(row.desc)}" placeholder="Description..." onchange="updateRow('${panel}','${esc(cat)}','${rid}','desc',this.value)"></td>
    <td class="td-note"><input type="text" value="${esc(row.note||'')}" placeholder="Note..." onchange="updateRow('${panel}','${esc(cat)}','${rid}','note',this.value)"></td>
    <td class="td-status">
      <select class="status-sel ${sc}" onchange="updateRow('${panel}','${esc(cat)}','${rid}','status',this.value);this.className='status-sel '+this.value">
        <option value="todo" ${row.status==='todo'?'selected':''}>À prévoir</option>
        <option value="pending" ${row.status==='pending'?'selected':''}>En attente</option>
        <option value="paid" ${row.status==='paid'?'selected':''}>Payé ✓</option>
      </select>
    </td>
    <td class="td-price"><input type="number" value="${row.price||''}" placeholder="0" min="0" step="0.01" onchange="updateRow('${panel}','${esc(cat)}','${rid}','price',this.value)"> €</td>
    <td><button class="btn-del" onclick="delRow('${panel}','${esc(cat)}','${rid}')">✕</button></td>`;
  return tr;
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

// ══════════ ACTIONS ══════════
function addRow(panel, cat) { data[panel][cat].rows.push(makeRow()); renderAll(); scheduleSave(); }
function delRow(panel, cat, id) { data[panel][cat].rows = data[panel][cat].rows.filter(r => String(r.id)!==id); renderAll(); scheduleSave(); }
function updateRow(panel, cat, id, field, val) {
  const row = data[panel][cat].rows.find(r => String(r.id)===id);
  if(row) { row[field]=val; updateGrandTotals(); scheduleSave(); }
}
function togglePaid(panel, cat, id) {
  const row = data[panel][cat].rows.find(r => String(r.id)===id);
  if(row) { row.status = row.status==='paid'?'todo':'paid'; renderAll(); scheduleSave(); }
}
function toggleCat(panel, cat) { data[panel][cat].open = !data[panel][cat].open; renderAll(); }

function updateGrandTotals() {
  [{panel:'mariage',cats:MARIAGE_CATS,sfx:'mariage'},{panel:'appart',cats:APPART_CATS,sfx:'appart'}].forEach(({panel,cats,sfx}) => {
    const rows = cats.flatMap(c => data[panel][c].rows);
    const total = rows.reduce((s,r)=>s+(parseFloat(r.price)||0),0);
    const paid  = rows.filter(r=>r.status==='paid').reduce((s,r)=>s+(parseFloat(r.price)||0),0);
    document.getElementById(`grand-total-${sfx}`).textContent = total.toLocaleString('fr-FR',{minimumFractionDigits:2})+' €';
    document.getElementById(`grand-paid-${sfx}`).textContent  = paid>0?`dont ${paid.toLocaleString('fr-FR',{minimumFractionDigits:2})} € payés`:'';
  });
}

// ══════════ CHECKLIST ══════════
function renderChecklists() {
  renderCL('mariage', data.checklist_mariage);
  renderCL('appart',  data.checklist_appart);
}
function renderCL(panel, items) {
  const ul = document.getElementById(`checklist-${panel}`);
  ul.innerHTML = '';
  items.forEach((item, i) => {
    const li = document.createElement('li');
    li.className = 'checklist-item'+(item.done?' done':'');
    li.innerHTML = `
      <div class="check-box ${item.done?'checked':''}" onclick="toggleCheck('${panel}',${i})">✓</div>
      <input class="item-text" value="${esc(item.text)}" onchange="editCheck('${panel}',${i},this.value)">
      <button class="btn-del" onclick="delCheck('${panel}',${i})">✕</button>`;
    ul.appendChild(li);
  });
}
function addCheck(panel) {
  const inp = document.getElementById(`new-check-${panel}`);
  const text = inp.value.trim(); if(!text) return;
  data[`checklist_${panel}`].push({text,done:false}); inp.value='';
  renderChecklists(); scheduleSave();
}
function toggleCheck(panel, i) { data[`checklist_${panel}`][i].done=!data[`checklist_${panel}`][i].done; renderChecklists(); scheduleSave(); }
function delCheck(panel, i) { data[`checklist_${panel}`].splice(i,1); renderChecklists(); scheduleSave(); }
function editCheck(panel, i, val) { data[`checklist_${panel}`][i].text=val; scheduleSave(); }

// ══════════ TIMER ══════════
const WEDDING = new Date('2026-05-30T11:00:00');
function updateTimer() {
  let diff = WEDDING - new Date();
  if(diff<0){document.querySelector('.timer-bar').innerHTML='<span style="font-family:Great Vibes,cursive;font-size:22px;color:var(--gold-light)">♡ C\'est aujourd\'hui ! Félicitations N & A ♡</span>';return;}
  const d=Math.floor(diff/86400000); diff-=d*86400000;
  const h=Math.floor(diff/3600000);  diff-=h*3600000;
  const m=Math.floor(diff/60000);    diff-=m*60000;
  const s=Math.floor(diff/1000);
  document.getElementById('t-days').textContent =String(d).padStart(2,'0');
  document.getElementById('t-hours').textContent=String(h).padStart(2,'0');
  document.getElementById('t-mins').textContent =String(m).padStart(2,'0');
  document.getElementById('t-secs').textContent =String(s).padStart(2,'0');
}
updateTimer(); setInterval(updateTimer,1000);

// ══════════ INIT ══════════
loadFromCloud();
</script>
